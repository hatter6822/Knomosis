# Lake build artefacts.
/.lake/
/build/
/lakefile.olean
/lake-packages/

# Lean editor / language-server scratch.
*.olean
*.ilean
*.hash
*.trace

# OS / editor noise.
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Lex codegen sidecar files are COMMITTED (not ignored).  Listed
# explicitly so a future contributor scanning .gitignore sees the
# inclusion intent; see `Lex/Inputs/README.md` and
# `docs/lex_implementation_plan.md` §5.
#
# LX-M2 audit-3 also commits the canonical manifest produced by
# `lake exe lex_codegen --canonical` (a structured summary of all
# Lex laws' metadata, byte-stable across runs).  Tracking it in
# git makes metadata changes visible at code-review time.
!Lex/Inputs/
!Lex/Inputs/*.json
!Lex/Inputs/canonical_manifest.txt
!Lex/Inputs/.gitkeep
!Lex/Inputs/README.md

# Lex codegen lock + tmp files (transient, used only during a `lake
# exe lex_codegen` invocation; never committed).
Lex/Inputs/*.lock
*.lex_codegen.tmp
*.json.tmp
