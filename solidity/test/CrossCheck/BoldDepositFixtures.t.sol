// Knomosis — proof-carrying state transition system.
// Cross-stack consumer for the GP.6.5 BOLD-specific deposit corpus.
//
pragma solidity ^0.8.20;

import {Vm} from "forge-std/Vm.sol";

import {CrossCheckFramework} from "./Framework.t.sol";
import {FeeSplitMath} from "test/utils/FeeSplitMath.sol";
import {KnomosisBridge} from "src/contracts/KnomosisBridge.sol";
import {MockBold} from "test/utils/MockBold.sol";

/// @title BoldDepositFixturesCrossCheck (GP.6.5)
/// @notice Solidity-side consumer of the Lean-authored `bold_deposit.json`
///         tri-stack corpus.  Re-verifies the BOLD deposit-with-fee path
///         independently of the Lean / Rust producers:
///           * an arithmetic recompute via `FeeSplitMath.split` — every
///             entry, hash-independent;
///           * the cross-stack budget-grant semantics
///             (`recipientBudgetAfter == budgetGrant`) — the NEW GP.6.5
///             dimension carried in this corpus;
///           * ETH/BOLD calibration parity (identical inputs ⇒ identical
///             split regardless of resource);
///           * the budget-clamp corners;
///           * the `actionCbe` / `recipientBudgetCbe` CBE side-channels'
///             well-formedness; and
///           * DIRECT live-contract deposits through `depositBoldWithFee`
///             and `depositETHWithFee` whose EMITTED
///             `(userAmount, poolAmount, budgetGrant)` must byte-match the
///             Lean-generated values — removing the `FeeSplitMath`
///             intermediary from the live cross-stack path.
///
/// @dev    The split + budget-grant are hash-independent, so every check
///         runs in EVERY binding mode (FNV fallback or keccak-linked).
///         All checks guard on `fixtureExists` so the suite skips
///         gracefully when the fixture has not yet been generated by
///         `lake test`.  The Lean generator wraps the corpus metadata
///         under a top-level `header` object, so all metadata reads use
///         `.header.<field>`.
contract BoldDepositFixturesCrossCheck is CrossCheckFramework {
    /// @dev Fixture file name under `test/CrossCheck/fixtures/`.
    string internal constant FIXTURE_NAME = "bold_deposit.json";

    /// @dev Local mirror of `KnomosisBridge.BOLD_TOKEN_ADDRESS`.
    address internal constant BOLD = 0x6440f144b7e50D6a8439336510312d2F54beB01D;

    /// @dev Mirror of `KnomosisBridge.RESOURCE_ID_BOLD`.
    uint64 internal constant RESOURCE_BOLD = 1;

    /// @dev Mirror of `KnomosisBridge.RESOURCE_ID_NATIVE_ETH`.
    uint64 internal constant RESOURCE_ETH = 0;

    /// @dev GP.5.5 safety-hardening roles (non-zero + distinct so a
    ///      BOLD-enabled bridge constructs; the cross-check never exercises
    ///      them).
    address internal constant BOLD_BREAKER = address(0xB12E6B6E);
    address internal constant BOLD_ADMIN = address(0xAD814);

    /// @dev Decoded fixture entry.
    struct Entry {
        uint64 resourceId;
        uint256 amount;
        uint16 chosenFeeBps;
        uint64 weiPerBudgetUnit;
        uint64 depositId;
        uint256 userAmount;
        uint256 poolAmount;
        uint64 budgetGrant;
        uint64 recipientBudgetAfter;
    }

    /// @notice Place a conformant BOLD mock at the pinned address so
    ///         BOLD-enabled bridges can be deployed in the live-contract
    ///         checks (the constructor reads `symbol()`).
    function setUp() public {
        MockBold impl = new MockBold();
        vm.etch(BOLD, address(impl).code);
    }

    // ------------------------------------------------------------------
    // Fixture decoding
    // ------------------------------------------------------------------

    /// @dev The corpus entry count, read from the nested `.header.count`.
    function _count(string memory raw) internal pure returns (uint256) {
        return vm.parseJsonUint(raw, ".header.count");
    }

    /// @dev Load entry `i` from the raw JSON.  `amount` / `userAmount` /
    ///      `poolAmount` are hex `bytes32` (parsed as `uint256`); the
    ///      remaining fields are JSON numbers.
    function _loadEntry(string memory raw, uint256 i)
        internal
        pure
        returns (Entry memory e)
    {
        string memory base = string.concat(".entries[", vm.toString(i), "]");
        e.resourceId = uint64(vm.parseJsonUint(raw, string.concat(base, ".resourceId")));
        e.amount = uint256(vm.parseJsonBytes32(raw, string.concat(base, ".amount")));
        // forge-lint: disable-next-line(unsafe-typecast)
        e.chosenFeeBps = uint16(vm.parseJsonUint(raw, string.concat(base, ".chosenFeeBps")));
        e.weiPerBudgetUnit =
            uint64(vm.parseJsonUint(raw, string.concat(base, ".weiPerBudgetUnit")));
        e.depositId = uint64(vm.parseJsonUint(raw, string.concat(base, ".depositId")));
        e.userAmount = uint256(vm.parseJsonBytes32(raw, string.concat(base, ".userAmount")));
        e.poolAmount = uint256(vm.parseJsonBytes32(raw, string.concat(base, ".poolAmount")));
        e.budgetGrant = uint64(vm.parseJsonUint(raw, string.concat(base, ".budgetGrant")));
        e.recipientBudgetAfter =
            uint64(vm.parseJsonUint(raw, string.concat(base, ".recipientBudgetAfter")));
    }

    // ------------------------------------------------------------------
    // tests
    // ------------------------------------------------------------------

    /// @notice Header shape: a non-empty corpus plus the constitutional
    ///         caps / pins.
    function test_fixture_header_shape() public view {
        if (!fixtureExists(FIXTURE_NAME)) return;
        string memory raw = readFixture(FIXTURE_NAME);
        assertGt(_count(raw), 0, "count > 0");
        assertEq(
            vm.parseJsonUint(raw, ".header.maxBudgetPerDeposit"),
            uint256(FeeSplitMath.MAX_BUDGET_PER_DEPOSIT),
            "maxBudgetPerDeposit == 1e12"
        );
        assertEq(uint256(FeeSplitMath.MAX_BUDGET_PER_DEPOSIT), 1_000_000_000_000, "1e12");
        assertEq(vm.parseJsonUint(raw, ".header.maxFeeBpsCap"), 5000, "maxFeeBpsCap");
        assertEq(
            vm.parseJsonUint(raw, ".header.minWeiPerBudgetUnit"), 1, "minWeiPerBudgetUnit"
        );
        assertEq(
            vm.parseJsonUint(raw, ".header.resourceIdBold"),
            uint256(RESOURCE_BOLD),
            "resourceIdBold"
        );
        assertEq(
            vm.parseJsonAddress(raw, ".header.boldTokenAddress"), BOLD, "boldTokenAddress"
        );
    }

    /// @notice Hash-independent arithmetic recompute: `FeeSplitMath.split`
    ///         reproduces every entry's split exactly; conservation and the
    ///         budget-cap bound hold.
    function test_perEntry_split_matches() public view {
        if (!fixtureExists(FIXTURE_NAME)) return;
        string memory raw = readFixture(FIXTURE_NAME);
        uint256 n = _count(raw);
        for (uint256 i = 0; i < n; i++) {
            Entry memory e = _loadEntry(raw, i);
            (uint256 u, uint256 p, uint64 b) =
                FeeSplitMath.split(e.amount, e.chosenFeeBps, e.weiPerBudgetUnit);
            assertEq(u, e.userAmount, "userAmount mismatch");
            assertEq(p, e.poolAmount, "poolAmount mismatch");
            assertEq(uint256(b), uint256(e.budgetGrant), "budgetGrant mismatch");
            assertEq(u + p, e.amount, "conservation user+pool==amount");
            assertLe(
                uint256(b),
                uint256(FeeSplitMath.MAX_BUDGET_PER_DEPOSIT),
                "budget within cap"
            );
        }
    }

    /// @notice Cross-stack budget-grant semantics: from a genesis-empty
    ///         budget at epoch 0 with freeTier 0, the recipient's
    ///         post-deposit `currentBudget` equals exactly the granted
    ///         `budgetGrant`.
    function test_perEntry_budgetGrant_equals_recipientBudgetAfter()
        public
        view
    {
        if (!fixtureExists(FIXTURE_NAME)) return;
        string memory raw = readFixture(FIXTURE_NAME);
        uint256 n = _count(raw);
        for (uint256 i = 0; i < n; i++) {
            Entry memory e = _loadEntry(raw, i);
            assertEq(
                e.recipientBudgetAfter,
                e.budgetGrant,
                "recipientBudgetAfter == budgetGrant"
            );
        }
    }

    /// @notice At least five entries exercise the budget clamp corner
    ///         (`budgetGrant == MAX_BUDGET_PER_DEPOSIT`).
    function test_clamp_corners() public view {
        if (!fixtureExists(FIXTURE_NAME)) return;
        string memory raw = readFixture(FIXTURE_NAME);
        uint256 n = _count(raw);
        uint256 clamped = 0;
        for (uint256 i = 0; i < n; i++) {
            Entry memory e = _loadEntry(raw, i);
            if (e.budgetGrant == FeeSplitMath.MAX_BUDGET_PER_DEPOSIT) {
                clamped++;
            }
        }
        assertGe(clamped, 5, "at least 5 clamp-corner entries");
    }

    /// @notice ETH/BOLD calibration parity: an ETH and a BOLD entry sharing
    ///         `(amount, chosenFeeBps, weiPerBudgetUnit)` must produce an
    ///         identical `(userAmount, poolAmount, budgetGrant)` split.
    function test_calibration_parity() public view {
        if (!fixtureExists(FIXTURE_NAME)) return;
        string memory raw = readFixture(FIXTURE_NAME);
        uint256 n = _count(raw);
        Entry[] memory entries = new Entry[](n);
        for (uint256 i = 0; i < n; i++) {
            entries[i] = _loadEntry(raw, i);
        }
        uint256 pairs = 0;
        for (uint256 a = 0; a < n; a++) {
            if (entries[a].resourceId != RESOURCE_BOLD) continue;
            for (uint256 b = 0; b < n; b++) {
                if (entries[b].resourceId != RESOURCE_ETH) continue;
                if (
                    entries[a].amount == entries[b].amount
                        && entries[a].chosenFeeBps == entries[b].chosenFeeBps
                        && entries[a].weiPerBudgetUnit == entries[b].weiPerBudgetUnit
                ) {
                    assertEq(
                        entries[a].userAmount, entries[b].userAmount, "parity userAmount"
                    );
                    assertEq(
                        entries[a].poolAmount, entries[b].poolAmount, "parity poolAmount"
                    );
                    assertEq(
                        entries[a].budgetGrant, entries[b].budgetGrant, "parity budgetGrant"
                    );
                    pairs++;
                }
            }
        }
        assertGe(pairs, 10, "at least 10 ETH/BOLD calibration pairs");
    }

    /// @notice Live-contract BOLD path: deploy a BOLD-enabled bridge
    ///         calibrated to each entry's rate, deposit via
    ///         `depositBoldWithFee`, and assert the emitted split
    ///         byte-matches the fixture.
    function test_perEntry_liveContract_bold_split_matches() public {
        if (!fixtureExists(FIXTURE_NAME)) return;
        string memory raw = readFixture(FIXTURE_NAME);
        uint256 n = _count(raw);
        address depositor = address(0xA11CE);
        for (uint256 i = 0; i < n; i++) {
            Entry memory e = _loadEntry(raw, i);
            if (e.resourceId != RESOURCE_BOLD) continue;
            KnomosisBridge bridge = _deployBoldBridge(e.weiPerBudgetUnit);
            MockBold(BOLD).mint(depositor, e.amount);
            vm.prank(depositor);
            MockBold(BOLD).approve(address(bridge), e.amount);
            vm.recordLogs();
            vm.prank(depositor);
            bridge.depositBoldWithFee(e.amount, e.chosenFeeBps);
            (uint256 u, uint256 p, uint64 b) =
                _decodeDepositWithFee(vm.getRecordedLogs());
            assertEq(u, e.userAmount, "live bold userAmount != fixture");
            assertEq(p, e.poolAmount, "live bold poolAmount != fixture");
            assertEq(uint256(b), uint256(e.budgetGrant), "live bold budgetGrant != fixture");
        }
    }

    /// @notice Live-contract ETH path: deploy a bridge whose ETH leg is
    ///         calibrated to each entry's rate (a BOLD-enabled bridge also
    ///         serves the ETH path), deposit via `depositETHWithFee`, and
    ///         assert the emitted split byte-matches the fixture.
    /// @dev `depositETHWithFee(uint16)` is `external payable`; the ETH
    ///      budget grant uses the bridge's immutable `weiPerBudgetUnitEth`,
    ///      so the bridge is constructed with
    ///      `weiPerBudgetUnitEth = entry.weiPerBudgetUnit`.
    function test_perEntry_liveContract_eth_split_matches() public {
        if (!fixtureExists(FIXTURE_NAME)) return;
        string memory raw = readFixture(FIXTURE_NAME);
        uint256 n = _count(raw);
        address depositor = address(0xA11CE);
        for (uint256 i = 0; i < n; i++) {
            Entry memory e = _loadEntry(raw, i);
            if (e.resourceId != RESOURCE_ETH) continue;
            KnomosisBridge bridge = _deployBridge(e.weiPerBudgetUnit, 1);
            vm.deal(depositor, e.amount);
            vm.recordLogs();
            vm.prank(depositor);
            bridge.depositETHWithFee{value: e.amount}(e.chosenFeeBps);
            (uint256 u, uint256 p, uint64 b) =
                _decodeDepositWithFee(vm.getRecordedLogs());
            assertEq(u, e.userAmount, "live eth userAmount != fixture");
            assertEq(p, e.poolAmount, "live eth poolAmount != fixture");
            assertEq(uint256(b), uint256(e.budgetGrant), "live eth budgetGrant != fixture");
        }
    }

    /// @notice Well-formedness of the CBE side-channels: `actionCbe` is a
    ///         0x-prefixed 72-byte hex string and `recipientBudgetCbe` an
    ///         18-byte hex string for every entry.  (Length is checked on
    ///         the hex string directly, no decode needed.  The Lean
    ///         `hexFromBytes` emits `"0x"` + two hex chars per byte with no
    ///         length prefix, so 72 bytes => 146 chars, 18 bytes => 38
    ///         chars.)
    function test_actionCbe_wellformed() public view {
        if (!fixtureExists(FIXTURE_NAME)) return;
        string memory raw = readFixture(FIXTURE_NAME);
        uint256 n = _count(raw);
        for (uint256 i = 0; i < n; i++) {
            string memory base = string.concat(".entries[", vm.toString(i), "]");
            bytes memory action =
                bytes(vm.parseJsonString(raw, string.concat(base, ".actionCbe")));
            bytes memory budget = bytes(
                vm.parseJsonString(raw, string.concat(base, ".recipientBudgetCbe"))
            );
            // 0x-prefixed
            assertGe(action.length, 2, "actionCbe has 0x prefix");
            assertEq(action[0], bytes1("0"), "actionCbe[0] == '0'");
            assertEq(action[1], bytes1("x"), "actionCbe[1] == 'x'");
            assertEq(budget[0], bytes1("0"), "recipientBudgetCbe[0] == '0'");
            assertEq(budget[1], bytes1("x"), "recipientBudgetCbe[1] == 'x'");
            // 72 bytes => "0x" + 144 hex chars
            assertEq(action.length, 2 + 144, "actionCbe decodes to 72 bytes");
            // 18 bytes => "0x" + 36 hex chars
            assertEq(budget.length, 2 + 36, "recipientBudgetCbe decodes to 18 bytes");
        }
    }

    // ------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------

    /// @notice Deploy a BOLD-enabled bridge with the given ETH-leg and
    ///         BOLD-leg `weiPerBudgetUnit` rates; full `[0, 5000]` fee
    ///         range, no TVL ceiling, migration unset.  Requires a BOLD
    ///         mock etched at the pin (done in `setUp`).
    function _deployBridge(uint64 ethRate, uint64 boldRate)
        internal
        returns (KnomosisBridge)
    {
        uint64[] memory rids = new uint64[](0);
        address[] memory toks = new address[](0);
        return new KnomosisBridge(
            KnomosisBridge.ConstructorArgs({
                knomosisVersionTag: keccak256("knomosis-bold-deposit-crosscheck"),
                attestor: address(0xA11CE),
                disputeVerifier: address(0xDEAD),
                sequencerStake: address(0xBEEF),
                migration: address(0),
                disputeWindowBlocks: 100,
                maxRedemptionWindowBlocks: 50,
                maxAttestationStaleBlocks: 200,
                cooldownBlocks: 50,
                tvlCap: type(uint256).max,
                minFeeBps: 0,
                maxFeeBps: 5000,
                weiPerBudgetUnitEth: ethRate,
                weiPerBudgetUnitBold: boldRate,
                boldTokenAddress: BOLD,
                boldTvlCap: type(uint256).max,
                boldCircuitBreaker: BOLD_BREAKER,
                boldAdmin: BOLD_ADMIN,
                enableLiquityAutoCircuitTrigger: false,
                erc20ResourceIds: rids,
                erc20TokenAddrs: toks
            })
        );
    }

    /// @notice Deploy a BOLD-enabled bridge calibrated to `boldRate` (ETH
    ///         leg pinned at the minimum valid rate of 1).
    function _deployBoldBridge(uint64 boldRate) internal returns (KnomosisBridge) {
        return _deployBridge(1, boldRate);
    }

    /// @notice Locate + decode the single `DepositWithFeeInitiated` entry
    ///         in a recorded-log array (skips any BOLD `Transfer` event).
    function _decodeDepositWithFee(Vm.Log[] memory logs)
        internal
        pure
        returns (uint256 userAmount, uint256 poolAmount, uint64 budgetGrant)
    {
        bytes32 sig = keccak256(
            "DepositWithFeeInitiated(address,uint64,address,uint256,uint256,uint64,uint64,bytes32)"
        );
        for (uint256 i = 0; i < logs.length; i++) {
            if (logs[i].topics.length == 4 && logs[i].topics[0] == sig) {
                (userAmount, poolAmount, budgetGrant,,) =
                    abi.decode(logs[i].data, (uint256, uint256, uint64, uint64, bytes32));
                return (userAmount, poolAmount, budgetGrant);
            }
        }
        revert("DepositWithFeeInitiated not found");
    }
}
