# Foundry
out/
cache/
broadcast/
forge-cache/

# Vendored dependencies (resolve via lib/* per remappings; do NOT commit
# the snapshots).  The setup script in scripts/solidity-setup.sh restores
# them to the pinned versions for CI.
lib/openzeppelin-contracts/
lib/forge-std/

# Test artefacts that the framework may write
test/fixtures/*.json
!test/fixtures/.gitkeep

# Bare `forge snapshot` output (a full-suite snapshot at the default
# path, including run-to-run-noisy fuzz entries).  The committed GP.11.9
# benchmark baseline lives at `test/BenchmarkGasV1_3.gas-snapshot` and is
# regenerated only via `make snapshot-gas`.
.gas-snapshot

# Editor / OS noise
.vscode/
.idea/
*.swp
.DS_Store
