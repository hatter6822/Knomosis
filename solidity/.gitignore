# Foundry
out/
cache/
broadcast/
forge-cache/

# Vendored dependencies (resolve via lib/* per remappings; do NOT commit
# the snapshots).  The setup script in scripts/solidity-setup.sh restores
# them to the pinned versions for CI.
lib/openzeppelin-contracts/
lib/forge-std/

# Test artefacts that the framework may write
test/fixtures/*.json
!test/fixtures/.gitkeep

# GP.11.9 gas-benchmark scratch output.
#
# `snapshots/` is forge's cheatcode gas-snapshot scratch dir
# (`vm.snapshotGasLastCall` / `vm.snapshotValue`); ANY forge run that
# includes the benchmark contracts rewrites it, and a PARTIAL run rewrites
# it with only the entries that ran — so it must never be committed.  The
# committed baseline is `test/BenchmarkGasV1_3.gas-baseline.json`,
# promoted from a verified full run only via `make snapshot-gas`.
#
# `.gas-snapshot` is bare `forge snapshot` output (a full-suite per-test
# snapshot, including run-to-run-noisy fuzz entries) — unrelated to the
# GP.11.9 flow and equally non-committable.
snapshots/
.gas-snapshot

# Deployment manifests written by DeploySepolia.s.sol.  Local / dry-run
# manifests (anvil, unknown chains) are scratch and never committed; a real
# testnet/mainnet manifest may be committed (`git add -f deployments/sepolia.json`)
# or published to your ops store — see docs/sepolia_deployment_runbook.md §5.
deployments/*.json
!deployments/.gitkeep

# Filled-in deploy env files (RPC keys / a raw signer key / actor addresses).
# The committed fill-in TEMPLATE is `deploy.sepolia.env.example`; the filled
# copy (`deploy.sepolia.env`, `deploy.mainnet.env`, …) holds secrets and must
# never be committed.  The `.example` suffix keeps the template tracked.
deploy.*.env

# Editor / OS noise
.vscode/
.idea/
*.swp
.DS_Store
