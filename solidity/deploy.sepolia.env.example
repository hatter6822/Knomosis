# ============================================================================
#  Knomosis — Sepolia VALUE-BEARING deploy environment (BOLD + AMM full suite)
# ============================================================================
#
#  HOW TO USE
#    1. cp solidity/deploy.sepolia.env.example solidity/deploy.sepolia.env
#    2. Fill in every `SET-THIS…` value below (search for "SET-THIS").
#    3. Review the sized economic parameters against YOUR gas price / asset
#       values (run `python3 scripts/economic_simulation.py`; see
#       docs/deployment_parameters.md).
#    4. Deploy with the one-command wrapper:
#           ./scripts/deploy_sepolia_launch.sh solidity/deploy.sepolia.env
#       (or source it yourself and run `cd solidity && make deploy-sepolia`).
#
#  The filled-in copy (`solidity/deploy.sepolia.env`) holds secrets and is
#  git-ignored — NEVER commit it.  Prefer a forge keystore
#  (KNOMOSIS_DEPLOYER_ACCOUNT) over a raw PRIVATE_KEY.
#
#  Every KNOMOSIS_* variable is read by `solidity/script/DeploySepolia.s.sol`
#  via `vm.envOr(...)`; the transport variables (RPC / Etherscan / signer)
#  are read by `solidity/Makefile`'s `deploy-sepolia` target and forge.
#  Full reference: docs/sepolia_deployment_runbook.md §4.4.  Parameter sizing:
#  docs/deployment_parameters.md.
# ============================================================================


# ---------------------------------------------------------------------------
# 1. DEPLOY TRANSPORT  (required — read by forge / the Makefile)
# ---------------------------------------------------------------------------

# Sepolia JSON-RPC endpoint (an Infura/Alchemy/your-node URL).  REQUIRED.
export SEPOLIA_RPC_URL="SET-THIS-https://sepolia.infura.io/v3/<key>"

# Etherscan API key for `--verify` source verification.  REQUIRED (a deploy
# without verified sources is opaque to users).
export ETHERSCAN_API_KEY="SET-THIS-etherscan-api-key"

# Signer for the deploy broadcast.  Provide EXACTLY ONE:
#   (A) RECOMMENDED — a forge keystore account name (the key never touches
#       the shell / process table).  Create once with:
#           cast wallet import knomosis-sepolia-deployer --interactive
export KNOMOSIS_DEPLOYER_ACCOUNT="SET-THIS-keystore-account-name"
#   (B) FALLBACK — a raw private key (ps/proc-visible; shadow-testnet ONLY).
#       Leave KNOMOSIS_DEPLOYER_ACCOUNT unset if you use this.
# export PRIVATE_KEY="0xSET-THIS-funded-deployer-key"
#
# Fund the deployer EOA with enough Sepolia ETH for ~9 contract-creation txs
# plus the AMM seed (see the runbook §1); a few test-ETH is ample.


# ---------------------------------------------------------------------------
# 2. PRODUCTION ACTORS  (required — independently custodied addresses)
# ---------------------------------------------------------------------------
# These are on-chain roles, NOT the deployer.  Each MUST be an address whose
# key you control (or a multisig).  Do NOT reuse the deployer EOA for roles
# that hold authority over funds.

# The L2 state attestor (signs bridge attestations).  REQUIRED.
export KNOMOSIS_ATTESTOR="SET-THIS-0xattestor"

# The sequencer (submits state roots; stake at risk).  REQUIRED.
export KNOMOSIS_SEQUENCER="SET-THIS-0xsequencer"

# The treasury (receives the 5% slashed-bond skim + fee splits).  Must NOT
# revert on ETH receipt.  REQUIRED.
export KNOMOSIS_TREASURY="SET-THIS-0xtreasury"

# The dispute adjudicator committee — a comma-separated list of DISTINCT,
# independently-custodied addresses (takes precedence over the base+count
# placeholder derivation, which is dry-run-only and has NO known keys).
# REQUIRED for a value-bearing deploy.  Example: three separate signers.
export KNOMOSIS_ADJUDICATORS="SET-THIS-0xadj1,0xadj2,0xadj3"
# Quorum (M-of-N) required to uphold a dispute.  Defaults to the full set
# size; set below the count for M-of-N.  Must be 1..=len(ADJUDICATORS).
# export KNOMOSIS_ADJUDICATOR_QUORUM="2"


# ---------------------------------------------------------------------------
# 3. BOLD + AMM  (this file provisions the FULL suite → both must be set)
# ---------------------------------------------------------------------------
# A "functional AMM" (which deploys + wires the disaster-recovery multisig)
# requires BOTH a BOLD token AND a non-zero seed ratio:
#     functionalAmm == (KNOMOSIS_BOLD_TOKEN != 0) && (KNOMOSIS_AMM_SEED_RATIO_BPS > 0)

# The Sepolia BOLD ERC-20 token address.  Off-mainnet it is authenticated by
# code-presence + `symbol() == "BOLD"` (there is no canonical mainnet pin to
# match).  REQUIRED for the BOLD+AMM suite.  (Set to 0x0 ONLY for an ETH-only
# deploy — then also set AMM_SEED_RATIO_BPS=0 and skip the multisig vars.)
export KNOMOSIS_BOLD_TOKEN="SET-THIS-0xsepolia-bold-token"

# Fraction (bps) of each pool-fee deposit routed to AMM liquidity.  MUST be
# > 0 for a functional AMM; must be <= MAX_AMM_SEED_RATIO_BPS.  REQUIRED > 0.
export KNOMOSIS_AMM_SEED_RATIO_BPS="SET-THIS-e.g.-500"

# The BOLD emergency-pause role (a multisig recommended; audit-21 B.2).
# Cannot move funds — pause-only.  REQUIRED for BOLD.
export KNOMOSIS_BOLD_CIRCUIT_BREAKER="SET-THIS-0xbold-breaker-multisig"

# The `setBoldTvlCap` role.  MUST be DISTINCT from the circuit breaker.
# REQUIRED for BOLD.
export KNOMOSIS_BOLD_ADMIN="SET-THIS-0xbold-admin-multisig"

# The AMM disaster-recovery multisig signers — a comma-separated list of
# DISTINCT, independently-custodied addresses (takes precedence over the
# placeholder derivation).  The 3-of-N kill switch: collusion of `threshold`
# signers must cost more than the AMM reserve value.  REQUIRED for the AMM,
# and len(SIGNERS) MUST be >= the threshold below (>= 3).
export KNOMOSIS_AMM_MULTISIG_SIGNERS="SET-THIS-0xsig1,0xsig2,0xsig3"
# The M-of-N disable threshold.  Constructor floor: MIN_DISABLE_THRESHOLD = 3.
export KNOMOSIS_AMM_MULTISIG_THRESHOLD="3"

# The Liquity auto-circuit-trigger reads MAINNET TroveManager oracles; it is
# force-disabled on any non-mainnet chain (Sepolia), so leave this false.
export KNOMOSIS_ENABLE_LIQUITY_AUTOTRIGGER="false"


# ---------------------------------------------------------------------------
# 4. ECONOMIC PARAMETERS  (sized — REVIEW against your gas price / asset value)
# ---------------------------------------------------------------------------
# These have testnet-sane defaults in the script, but a VALUE-BEARING deploy
# must size them from `scripts/economic_simulation.py` for YOUR assumptions.
# The values below are conservative starting points; re-run the harness with
# them and confirm the IC-1/2/5/6 asserts pass before broadcasting.
# ALL are immutable after construction — a change needs a full migration.

# Minimum fault-proof challenge bond (wei).  The harness floor is ~0.115 ETH
# at 50 gwei / a depth-2^20 trace; the value below adds margin for gas spikes.
# RE-DERIVE for your target gas price × trace depth; keep >= the harness floor
# AFTER the 5% treasury skim (IC-1).  Script default (0.05 ETH) is too low for
# value-bearing.
export KNOMOSIS_MIN_CHALLENGE_BOND="150000000000000000"   # 0.15 ETH

# Sequencer per-root submission bond (wei).  Size >= the value extractable by
# submitting one invalid root.
export KNOMOSIS_STATE_ROOT_BOND="1000000000000000000"     # 1 ETH

# Challenger share of a slashed sequencer stake (bps; remainder burns).
export KNOMOSIS_SLASH_BPS="5000"                          # 50%

# Global bridged-value ceiling (wei).  Start CONSERVATIVE on a young
# value-bearing deployment and raise via migration as confidence grows.
# (Script default is 100000 ETH — far too high for a launch.)
export KNOMOSIS_TVL_CAP="100000000000000000000"           # 100 ETH

# Per-BOLD TVL sub-cap (wei).  Must be <= KNOMOSIS_TVL_CAP.  Defaults to the
# global cap if unset; bound single-asset (BOLD) exposure tighter.
export KNOMOSIS_BOLD_TVL_CAP="50000000000000000000"       # 50 ETH-equivalent

# Depositor-chosen pool-fee band (bps).  minFeeBps <= maxFeeBps <= 5000.
export KNOMOSIS_MIN_FEE_BPS="0"
export KNOMOSIS_MAX_FEE_BPS="5000"

# Fee-value -> action-budget conversion (wei per budget unit; must be > 0).
export KNOMOSIS_WEI_PER_BUDGET_UNIT_ETH="1000000000"      # 1 gwei/unit
export KNOMOSIS_WEI_PER_BUDGET_UNIT_BOLD="1000000000"


# ---------------------------------------------------------------------------
# 5. FAULT-PROOF + BRIDGE WINDOWS  (L1 blocks / counts — topology, not economics)
# ---------------------------------------------------------------------------
# Defaults are Sepolia-sane (~12 s/block).  The withdrawal window must cover
# the dispute window PLUS a full worst-case game (ceil(log2 N) rounds).

export KNOMOSIS_DISPUTE_WINDOW="50400"                    # ~7 days
export KNOMOSIS_MAX_REDEMPTION="36000"                    # ~5 days
export KNOMOSIS_ATTEST_STALE="7200"                       # ~24 h
export KNOMOSIS_COOLDOWN="7200"                           # ~24 h
export KNOMOSIS_STATE_ROOT_DISPUTE_WINDOW="216000"        # ~30 days
export KNOMOSIS_MIN_SUBMISSION_INTERVAL="100"             # anti-spam floor
export KNOMOSIS_MAX_OUTSTANDING_ROOTS="100"
export KNOMOSIS_WITHDRAWAL_WINDOW_BLOCKS="216000"         # >= dispute + game
export KNOMOSIS_BISECTION_TIMEOUT_BLOCKS="21600"          # ~3 days / round
export KNOMOSIS_MIN_BISECTION_STEP_INTERVAL="5"           # < timeout (guard)


# ---------------------------------------------------------------------------
# 6. MANIFEST OUTPUT  (optional — where the addresses manifest is written)
# ---------------------------------------------------------------------------
# Defaults to solidity/deployments/<network>.json (i.e. .../sepolia.json),
# which the L2 daemon stack + gateway consume.  Leave unset unless relocating.
# export KNOMOSIS_MANIFEST_OUT="deployments/sepolia.json"

# Deployment version tag (bytes32; defaults to keccak256("knomosis-sepolia-v1")).
# export KNOMOSIS_VERSION_TAG="0x..."
